@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Deluxe Room Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(to right, #f8f9fa, #eef2f7);
            font-family: 'Poppins', sans-serif;
        }

        .room-container {
            max-width: 1100px;
            margin: 40px auto;
        }

        .room-card {
            border: none;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
            background: #fff;
        }

        .room-header {
            background: linear-gradient(135deg, #ffb347, #ff8c00);
            color: white;
            padding: 30px;
            text-align: center;
            position: relative;
        }

            .room-header h1 {
                font-size: 38px;
                font-weight: 700;
            }

        .badge-room {
            background: #198754;
            padding: 10px 18px;
            font-size: 15px;
            border-radius: 30px;
        }

        .room-img {
            width: 100%;
            height: 500px;
            object-fit: cover;
        }

        .price {
            color: #ff8c00;
            font-size: 40px;
            font-weight: 700;
        }

        .capacity {
            color: #555;
            font-weight: 600;
        }

        .section-title {
            color: #ff8c00;
            font-size: 26px;
            font-weight: 700;
            margin-top: 30px;
        }

        .description {
            color: #666;
            font-size: 17px;
            line-height: 1.9;
            text-align: justify;
        }

        .facility-list {
            list-style: none;
            padding: 0;
        }

            .facility-list li {
                background: #fffaf2;
                border-left: 5px solid #ff8c00;
                padding: 15px 20px;
                margin-bottom: 12px;
                border-radius: 12px;
                font-size: 18px;
            }

        .btn-book {
            background: linear-gradient(135deg, #ffb347, #ff8c00);
            color: white;
            border: none;
            padding: 14px 45px;
            font-size: 18px;
            font-weight: 600;
            border-radius: 50px;
            text-decoration: none;
        }

            .btn-book:hover {
                color: white;
                background: #e67e00;
            }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: white;
            color: #ff8c00;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
        }

            .back-btn:hover {
                background: #fff3dd;
                color: #d97706;
            }
    </style>
</head>
<body>

    <div class="container room-container">

        <div class="card room-card">

            <div class="room-header">

                <a href="@Url.Action("Room","rooms")" class="back-btn">
                    ← Back
                </a>

                <h1>✨ Deluxe Room</h1>
                <span class="badge badge-room">Available</span>

            </div>

            <img src="~/Imagess/rooms/Delex.png" class="room-img" alt="Deluxe Room">

            <div class="card-body p-4">

                <div class="row">
                    <div class="col-md-6">
                        <h2 class="price">₹4,500 / Night</h2>
                    </div>

                    <div class="col-md-6 text-md-end">
                        <h4 class="capacity">👥 3 Guests</h4>
                    </div>
                </div>

                <h3 class="section-title">Room Description</h3>

                <p class="description">
                    Experience luxury and comfort in our Deluxe Room. Designed with
                    elegant interiors and premium amenities, this room is ideal for
                    families, couples, and business travelers looking for an enhanced
                    stay experience.
                </p>

                <h3 class="section-title">Facilities & Amenities</h3>

                <ul class="facility-list">
                    <li>📶 Free Wi-Fi</li>
                    <li>❄️ Air Conditioner</li>
                    <li>📺 Smart TV</li>
                    <li>🧊 Mini Fridge</li>
                    <li>☕ Tea/Coffee Maker</li>
                    <li>🍽️ Complimentary Breakfast</li>
                </ul>

                <div class="text-center mt-4">
                    <a href="book_room" class="btn-book">
                        Book Now
                    </a>
                </div>

            </div>

        </div>

    </div>

</body>
</html>