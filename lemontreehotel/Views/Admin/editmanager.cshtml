@model lemontreehotel.Models.manager

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <title>Edit Manager - Lemon Tree Hotel</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('../../Imagess/facade-night-view.jpg');
            background-size: cover;
            background-position: center;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .edit-container {
            width: 450px;
            background: rgba(255, 255, 255, 0.95);
            padding: 35px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            border-top: 8px solid #f4c430;
        }

        .logo {
            text-align: center;
            font-size: 30px;
            font-weight: bold;
            color: #f4c430;
            margin-bottom: 5px;
        }

        .sub-title {
            text-align: center;
            color: #333;
            margin-bottom: 25px;
            font-size: 16px;
        }

        label {
            font-weight: 600;
            color: #222;
            display: block;
            margin-bottom: 6px;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 10px;
            outline: none;
            margin-bottom: 15px;
            font-size: 15px;
            transition: 0.3s;
        }

            input[type="text"]:focus,
            input[type="password"]:focus {
                border-color: #f4c430;
                box-shadow: 0 0 8px rgba(244,196,48,0.5);
            }

        .btn-update {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 10px;
            background: #f4c430;
            color: black;
            font-size: 17px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

            .btn-update:hover {
                background: #e0b200;
                transform: scale(1.02);
            }
    </style>
</head>

<body>

    <div class="edit-container">

        <div class="logo">🍋 Lemon Tree Hotel</div>
        <div class="sub-title">Edit Manager Details</div>

        @using (Html.BeginForm())
        {
            @Html.HiddenFor(x => x.id)

            <label>Name</label>
            @Html.TextBoxFor(x => x.name)

            <label>Email</label>
            @Html.TextBoxFor(x => x.email)

            <label>Phone</label>
            @Html.TextBoxFor(x => x.phone)

            <label>Password</label>
            @Html.PasswordFor(x => x.password)

            <label>Branch</label>
            @Html.TextBoxFor(x => x.Branch)

            <input type="submit" value="Update Manager" class="btn-update" />
        }

    </div>

</body>
</html>