@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Standard Room Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f5f7fa;
            font-family: 'Segoe UI', sans-serif;
        }

        .room-container {
            max-width: 1100px;
            margin: 40px auto;
        }

        .room-card {
            border: none;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0px 8px 25px rgba(0,0,0,0.15);
            background: white;
        }

        .room-img {
            width: 100%;
            height: 450px;
            object-fit: cover;
        }

        .room-header {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: white;
            padding: 20px;
            text-align: center;
        }

        .price {
            color: #f59e0b;
            font-size: 32px;
            font-weight: bold;
        }

        .capacity {
            font-size: 20px;
            color: #555;
            font-weight: 600;
        }

        .section-title {
            color: #f59e0b;
            font-weight: bold;
            margin-top: 25px;
            margin-bottom: 15px;
        }

        .facility-list {
            list-style: none;
            padding: 0;
        }

            .facility-list li {
                padding: 10px;
                margin-bottom: 10px;
                background: #fff8e7;
                border-left: 5px solid #f59e0b;
                border-radius: 8px;
                font-size: 17px;
            }

        .description {
            color: #666;
            line-height: 1.8;
            font-size: 17px;
        }

        .btn-book {
            background: #f59e0b;
            color: white;
            font-weight: bold;
            padding: 12px 35px;
            border-radius: 10px;
            border: none;
            transition: 0.3s;
        }

            .btn-book:hover {
                background: #d97706;
                color: white;
            }

        .badge-room {
            background: #198754;
            font-size: 15px;
            padding: 8px 15px;
        }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: white;
            color: #f59e0b;
            border: 2px solid white;
            font-weight: bold;
            padding: 8px 18px;
            border-radius: 8px;
            text-decoration: none;
            transition: 0.3s;
        }

            .back-btn:hover {
                background: #fff8e7;
                color: #d97706;
            }
    </style>
</head>
<body>

    <div class="container room-container">


        <div class="card room-card">
            <a href="@Url.Action("Room","rooms")" class="back-btn">
                ← Back
            </a>

            <div class="room-header">
                <h1>🏨 Standard Room</h1>
                <span class="badge badge-room">Available</span>
            </div>

            <img src="~/Imagess/rooms/standard.png" class="room-img" alt="Standard Room">

            <div class="card-body p-4">

                <div class="row">
                    <div class="col-md-6">
                        <h2 class="price">₹2,500 / Night</h2>
                    </div>

                    <div class="col-md-6 text-md-end">
                        <h4 class="capacity">👥 2 Guests</h4>
                    </div>
                </div>

                <h3 class="section-title">Room Description</h3>

                <p class="description">
                    Enjoy a comfortable stay in our Standard Room featuring modern amenities,
                    elegant interiors, high-speed Wi-Fi, and 24/7 room service.
                    Perfect for business and leisure travelers seeking comfort at an affordable price.
                </p>

                <h3 class="section-title">Facilities & Amenities</h3>

                <h3 class="section-title">Facilities & Amenities</h3>

                <ul class="facility-list">
                    <li>📶 Free Wi-Fi</li>
                    <li>❄️ Air Conditioner</li>
                    <li>📺 LED TV</li>
                    <li>🛎️ Room Service</li>
                    <li>🍽️ Complimentary Breakfast</li>
                </ul>

                <div class="text-center mt-4">
                    <a href="#" class="btn btn-book">
                        Book Now
                    </a>
                </div>


                <div class="room-header position-relative">



                    <h1>🏨 Standard Room</h1>
                    <span class="badge badge-room">Available</span>

                </div>
            </div>

        </div>

    </div>

</body>
</html>