
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Lemon Tree Hotel - Rooms</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f8f9fa;
        }

        .title {
            text-align: center;
            margin: 30px 0;
            color: #f59e0b;
            font-weight: bold;
        }

        .room-card {
            border: none;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0px 5px 15px rgba(0,0,0,0.15);
            transition: 0.3s;
        }

            .room-card:hover {
                transform: translateY(-5px);
            }

            .room-card img {
                height: 220px;
                object-fit: cover;
            }

        .price {
            color: #f59e0b;
            font-size: 22px;
            font-weight: bold;
        }

        .guest {
            font-weight: 600;
            color: #555;
        }

        .btn-room {
            background: #f59e0b;
            color: white;
            border: none;
        }

            .btn-room:hover {
                background: #d97706;
                color: white;
            }
    </style>
</head>

<body>

    <div class="container">

        <h1 class="title">🏨 Lemon Tree Hotel Rooms</h1>

        <div class="row">

            <!-- Standard Room -->
            <div class="col-md-4 mb-4">
                <div class="card room-card">
                    <img src="~/Imagess/rooms/standard.png"Delex class="card-img-top" alt="Standard Room">

                    <div class="card-body">
                        <h4>Standard Room</h4>
                        <p class="price">₹2,500 / Night</p>
                        <p class="guest">👥 2 Guests</p>
                        <a href="#" class="btn btn-room w-100">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Deluxe Room -->
            <div class="col-md-4 mb-4">
                <div class="card room-card">
                    <img src="~/Imagess/rooms/Delex.png" class="card-img-top" alt="Deluxe Room">

                    <div class="card-body">
                        <h4>Deluxe Room</h4>
                        <p class="price">₹4,000 / Night</p>
                        <p class="guest">👥 3 Guests</p>
                        <a href="#" class="btn btn-room w-100">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Super Deluxe Room -->
            <div class="col-md-4 mb-4">
                <div class="card room-card">
                    <img src="~/Content/RoomImages/superdeluxe.jpg" class="card-img-top" alt="Super Deluxe Room">

                    <div class="card-body">
                        <h4>Super Deluxe Room</h4>
                        <p class="price">₹5,500 / Night</p>
                        <p class="guest">👥 4 Guests</p>
                        <a href="#" class="btn btn-room w-100">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Family Room -->
            <div class="col-md-4 mb-4">
                <div class="card room-card">
                    <img src="~/Imagess/rooms/familyroom.png" class="card-img-top" alt="Family Room">

                    <div class="card-body">
                        <h4>Family Room</h4>
                        <p class="price">₹7,000 / Night</p>
                        <p class="guest">👥 6 Guests</p>
                        <a href="#" class="btn btn-room w-100">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Presidential Suite -->
            <div class="col-md-4 mb-4">
                <div class="card room-card">
                    <img src="~/Imagess/rooms/presendiital.jpg" class="card-img-top" alt="Presidential Suite">

                    <div class="card-body">
                        <h4>Presidential Suite</h4>
                        <p class="price">₹15,000 / Night</p>
                        <p class="guest">👥 8 Guests</p>
                        <a href="#" class="btn btn-room w-100">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Meeting Room -->
            <div class="col-md-4 mb-4">
                <div class="card room-card">
                    <img src="~/Imagess/rooms/businessroom.jpg" class="card-img-top" alt="Meeting Room">

                    <div class="card-body">
                        <h4>Meeting Room</h4>
                        <p class="price">₹10,000 / Day</p>
                        <p class="guest">👥 6 Persons</p>
                        <a href="#" class="btn btn-room w-100">View Details</a>
                    </div>
                </div>
            </div>

        </div>

    </div>

</body>
</html>
