@model List<lemontreehotel.Models.userRegister>
@using System.Data.SqlClient;


    @{
        Layout = null;
    }

    <!DOCTYPE html>

    <html>
    <head>

        <title>Manage Users</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

        <style>

            body {
                background: #f5f5f5;
                font-family: Arial;
            }

            .container {
                margin-top: 30px;
                background: white;
                padding: 30px;
                border-radius: 10px;
                box-shadow: 0 0 10px gray;
            }

            h1 {
                margin-bottom: 25px;
            }

            .btn-add {
                margin-bottom: 20px;
            }
        </style>

    </head>

    <body>

        <div class="container">

            <h1>Manage Users</h1>

            <a href="" class="btn btn-success btn-add">
                + Add User
            </a>

            <table class="table table-bordered table-hover">

                <thead class="table-light">

                    <tr>

                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Mobile</th>
                        <th>Gender</th>
                        <th>Date Of Birth</th>
                        <th>Address</th>
                        <th>Password</th>
                        <th>Confrom_Password</th>

                    </tr>
                    @{
                        string path = "Data Source=pralhad\\SQLEXPRESS;Initial Catalog=ItHotel;Integrated Security=True";

                        SqlConnection sc = new SqlConnection(path);
                        sc.Open();

                        string querry = "select * from users";
                        SqlCommand cmd = new SqlCommand(querry, sc);
                        SqlDataReader reader = cmd.ExecuteReader();

                        while (reader.Read())
                        {
                            <tr>
                                <td>@reader["id"]</td>
                                <td>@reader["name"]</td>
                                <td>@reader["email"]</td>
                                <td>@reader["mobile_no"]</td>
                                <td>@reader["gender"]</td>
                                <td>@reader["date_of_birth"]</td>
                                <td>@reader["address"]</td>
                                <td>@reader["password"]</td>
                                <td>@reader["confirm_password"]</td>

                            </tr>
                        }
                    }

                </thead>


            </table>

        </div>

    </body>
</html>
