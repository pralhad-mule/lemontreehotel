@Model lemontreehotel.models.manager

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
    charset="UTF-8">
    <title>Manager Registration - Lemon Tree Hotel</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Background */
        body {
            height: 100vh;
            background: url('https://images.unsplash.com/photo-1566073771259-6a8506099945') no-repeat center/cover;
            display: flex;
            justify-content: center;
            align-items: center;
        }

            /* Overlay */
            body::before {
                content: "";
                position: absolute;
                width: 100%;
                height: 100%;
                background: rgba(0,0,0,0.6);
            }

        /* Container */
        .container {
            position: relative;
            z-index: 1;
        }

        /* Form Box */
        .form-box {
            width: 360px;
            padding: 30px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(12px);
            border-radius: 12px;
            color: white;
            box-shadow: 0 0 25px rgba(0,0,0,0.5);
        }

            .form-box h2 {
                text-align: center;
                margin-bottom: 20px;
            }

        /* Input Box */
        .input-box {
            position: relative;
            margin-bottom: 20px;
        }

            .input-box input,
            .input-box select {
                width: 100%;
                padding: 10px;
                background: transparent;
                border: none;
                border-bottom: 2px solid white;
                color: white;
                outline: none;
            }

            /* Label Animation */
            .input-box label {
                position: absolute;
                top: 10px;
                left: 0;
                font-size: 14px;
                transition: 0.3s;
                pointer-events: none;
            }

            .input-box input:focus ~ label,
            .input-box input:valid ~ label {
                top: -10px;
                font-size: 12px;
                color: #f4c542;
            }

        /* Select Style */
        select option {
            color: black;
        }

        /* Button */
        button {
            width: 100%;
            padding: 12px;
            background: #f4c542;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
        }

            button:hover {
                background: #d4a62a;
            }
    </style>


</head>
<body>

    <div class="container">
        <div class="form-box">
            <h2>Manager Registration</h2>

            @using (Html.BeginForm("Index", "Manager", FormMethod.Post))
            {
                <div class="input-box">
                    <input type="text" name="name" required>
                    <label>Full Name</label>
                </div>

                <div class="input-box">
                    <input type="email" name="email" required>
                    <label>Email</label>
                </div>

                <div class="input-box">
                    <input type="text" name="phone" required>
                    <label>Phone Number</label>
                </div>


                <div class="input-box">
                    <input type="password" name="password" required>
                    <label>Password</label>
                </div>

                <div class="input-box">
                    <input type="text" name="branch" required>
                    <label>Branch</label>
                </div>

                <a href="Admin/Adminlogin"> 
                    <button type="submit">Register</button>
                </a>
            }
          @ViewData["status"]


        </div>
    </div>

</body>
</html>

