@Model lemontreehotel.models.Booking

{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Hotel Booking Form</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            /* ✅ Online Hotel Image */
            background-image: url('https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=1400&q=80');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
        }

        .container {
            width: 500px;
            margin: 50px auto;
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0px 0px 15px rgba(0,0,0,0.2);
        }

        h2 {
            text-align: center;
            color: #333;
            margin-bottom: 20px;
        }

        label {
            font-weight: bold;
            display: block;
            margin-top: 10px;
            color: #444;
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border: 1px solid #ccc;
            border-radius: 6px;
            box-sizing: border-box;
        }

            input:focus, select:focus {
                border-color: #2196F3;
                outline: none;
                box-shadow: 0px 0px 5px #90caf9;
            }

        .row {
            display: flex;
            gap: 10px;
        }

            .row div {
                flex: 1;
            }

        button {
            width: 100%;
            padding: 12px;
            margin-top: 20px;
            background: #2196F3;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
        }

            button:hover {
                background: #1976D2;
            }

        .price-box {
            background: #f1f8e9;
            padding: 10px;
            margin-top: 10px;
            border-radius: 6px;
            text-align: center;
            font-weight: bold;
            color: #2e7d32;
        }
    </style>
</head>

<body>

    <div class="container">

        <h2>Hotel Booking Form</h2>

        @using (Html.BeginForm("book_room", "rooms", FormMethod.Post))
        {
            <label> Name</label>
            <input type="text" placeholder="Enter your name" name="custimername">

            <label>Email</label>
            <input type="email" placeholder="Enter email" name="email">

            <label>Phone</label>
            <input type="text" placeholder="Enter phone number" name="phone">

            <label>Room Type</label>
            <select name="roomtype">
                <option>-- Select Room --</option>
                <option> Standard </option>
                <option> Deluxe </option>
                <option> Super Deluxe </option>
                <option> Family </option>
                <option> President </option>
                <option> Meeting </option>
                <option>Executive</option>
                <option> Premium </option>
                <option> Luxury </option>
                <option> Business </option>

            </select>

            <div class="row">
                <div>
                    <label>Check-In</label>
                    <input type="date" name="CheckInDate">
                </div>

                <div>
                    <label>check-Out</label>
                    <input type="date" name="CheckOutDate">
                </div>
            </div>

            <div class="row">
                <div id="aadhaarContainer">
                    <label>No-Guests</label>
                    <input type="number" placeholder="No. of guests" name="Guests" id="Guests">
                </div>

                <div>
                    <label>Price/Night</label>
                    <input type="number" placeholder="₹" name="Price_Per_Nigh">

                </div>

                <div>
                    <label>TotalPrice </label>
                    <input type="number" placeholder="₹" name="totalprice" id="totalprice">

                </div>
            </div>
                  <button type="submit">Book Now</button>
            @ViewData["status"]


        }

    </div>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const roomType = document.querySelector("[name='roomtype']");
            const guests = document.querySelector("[name='Guests']");
            const price = document.querySelector("[name='Price_Per_Nigh']");
            const checkIn = document.querySelector("[name='CheckInDate']");
            const checkOut = document.querySelector("[name='CheckOutDate']");
            const totalPrice = document.getElementById("totalprice");

            function updateRoomDetails() {

                if (roomType.value === "Standard") {
                    guests.value = 2;
                    price.value = 2500;
                }
                else if (roomType.value === "Deluxe") {
                    guests.value = 3;
                    price.value = 4000;
                }
                else if (roomType.value === "Super Deluxe") {
                    guests.value = 4;
                    price.value = 5500;
                }
                else if (roomType.value === "Family") {
                    guests.value = 6;
                    price.value = 7000;
                }
                else if (roomType.value === "Presidential") {
                    guests.value = 8;
                    price.value = 15000;
                }
                else if (roomType.value === "Meeting") {
                    guests.value = 6;
                    price.value = 1000;
                }
                else if (roomType.value === "Executive") {
                    guests.value = 4;
                    price.value = 6500;
                }
                else if (roomType.value === "Premium") {
                    guests.value = 4;
                    price.value = 8000;
                }
                else if (roomType.value === "Luxury") {
                    guests.value = 5;
                    price.value = 10000;
                }
                else if (roomType.value === "Business") {
                    guests.value = 3;
                    price.value = 9000;
                }

                calculateTotal();
            }

            function calculateTotal() {

                if (checkIn.value && checkOut.value && price.value) {

                    let inDate = new Date(checkIn.value);
                    let outDate = new Date(checkOut.value);

                    let days = (outDate - inDate) / (1000 * 60 * 60 * 24);

                    if (days > 0) {
                        totalPrice.value = days * parseInt(price.value);
                    }
                    else {
                        totalPrice.value = "";
                    }
                }
            }

            roomType.addEventListener("change", updateRoomDetails);
            checkIn.addEventListener("change", calculateTotal);
            checkOut.addEventListener("change", calculateTotal);

        });

        


    </script>

</body>
</html>