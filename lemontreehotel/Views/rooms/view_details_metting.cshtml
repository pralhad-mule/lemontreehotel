@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Meeting Room Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(to right, #f8f9fa, #eef2f7);
            font-family: 'Poppins', sans-serif;
        }

        .room-container {
            max-width: 1100px;
            margin: 40px auto;
        }

        .room-card {
            border: none;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
            background: #fff;
        }

        .room-header {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            color: white;
            padding: 30px;
            text-align: center;
            position: relative;
        }

            .room-header h1 {
                font-size: 38px;
                font-weight: 700;
            }

        .badge-room {
            background: #198754;
            padding: 10px 18px;
            font-size: 15px;
            border-radius: 30px;
        }

        .room-img {
            width: 100%;
            height: 500px;
            object-fit: cover;
        }

        .price {
            color: #2a5298;
            font-size: 40px;
            font-weight: 700;
        }

        .capacity {
            color: #555;
            font-weight: 600;
        }

        .section-title {
            color: #2a5298;
            font-size: 26px;
            font-weight: 700;
            margin-top: 30px;
        }

        .description {
            color: #666;
            font-size: 17px;
            line-height: 1.9;
            text-align: justify;
        }

        .facility-list {
            list-style: none;
            padding: 0;
        }

            .facility-list li {
                background: #f0f4ff;
                border-left: 5px solid #2a5298;
                padding: 15px 20px;
                margin-bottom: 12px;
                border-radius: 12px;
                font-size: 18px;
            }

        .btn-book {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            color: white;
            border: none;
            padding: 14px 45px;
            font-size: 18px;
            font-weight: 600;
            border-radius: 50px;
            text-decoration: none;
        }

            .btn-book:hover {
                color: white;
                background: #1a3561;
            }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: white;
            color: #2a5298;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
        }

            .back-btn:hover {
                background: #e6edff;
            }
    </style>
</head>

<body>

    <div class="container room-container">

        <div class="card room-card">

            <div class="room-header">

                <a href="@Url.Action("Room","rooms")" class="back-btn">
                    ← Back
                </a>

                <h1>🏢 Meeting Room</h1>
                <span class="badge badge-room">Available</span>

            </div>

            <img src="~/Imagess/rooms/businessroom.jpg" class="room-img" alt="Meeting Room">

            <div class="card-body p-4">

                <div class="row">
                    <div class="col-md-6">
                        <h2 class="price">₹10,000 / Day</h2>
                    </div>

                    <div class="col-md-6 text-md-end">
                        <h4 class="capacity">👥 6 Persons</h4>
                    </div>
                </div>

                <h3 class="section-title">Room Description</h3>

                <p class="description">
                    Our Meeting Room is designed for corporate meetings, presentations,
                    interviews, and business discussions. It offers a professional
                    environment with modern technology support and comfortable seating
                    for productive sessions.
                </p>

                <h3 class="section-title">Facilities & Amenities</h3>

                <ul class="facility-list">
                    <li>📶 High-Speed Wi-Fi</li>
                    <li>📽️ Projector & Presentation Screen</li>
                    <li>🪑 Conference Table & Comfortable Chairs</li>
                    <li❄️ Air Conditioning</li>
                <li>🎤 Microphone & Speaker System</li>
                <li>☕ Tea / Coffee Service</li>
                <li>🧑‍💼 Whiteboard & Marker Set</li>
                <li>🔌 Charging Ports & Power Backup</li>
                <li>🧹 Daily Cleaning Service</li>
                <li>🅿️ Parking Facility</li>
                </ul>

                <div class="text-center mt-4">
                    <a href="#" class="btn-book">Book Now</a>
                </div>

            </div>

        </div>

    </div>

</body>
</html>