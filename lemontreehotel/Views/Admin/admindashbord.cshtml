@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            margin: 0;
            background: #f5f5f5;
            font-family: Arial;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            background: #212529;
            position: fixed;
        }

            .sidebar h3 {
                color: white;
                text-align: center;
                padding: 20px;
                border-bottom: 1px solid gray;
            }

            .sidebar a {
                display: block;
                color: white;
                text-decoration: none;
                padding: 15px 20px;
                font-size: 17px;
            }

                .sidebar a:hover {
                    background: #ffc107;
                    color: black;
                }

        .content {
            margin-left: 250px;
            padding: 30px;
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,.1);
        }

            .card h2 {
                font-weight: bold;
            }
    </style>

</head>

<body>

    <div class="sidebar">

        <h3>Admin Panel</h3>

        <a href="/Admin/admindashbord">🏠 Dashboard</a>

        <a href="/Admin/Manage_Managers">👨‍💼 Manage Managers</a>

        <a href="/Admin/Manage_User">👤 Manage Users</a>

        <a href="/Admin/RoomManagement">🛏 Room Management</a>

        <a href="/Admin/RoomBooking">📅 Room Booking</a>

        <a href="/Admin/Payment">💳 Payments</a>

        <a href="/Admin/Visitors">👥 Visitors</a>

        <a href="/Admin/Reports">📊 Reports</a>

        <a href="/Admin/Settings">⚙ Settings</a>

        <a href="/Home/Index">🚪 Logout</a>

    </div>

    <div class="content">

        <h2>Welcome Admin 👋</h2>

        <div class="row mt-4">

            <div class="col-md-3 mb-4">
                <div class="card text-center p-4 bg-primary text-white">
                    <h5>Total Managers</h5>
                    <h2>@ViewBag.TotalManagers</h2>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card text-center p-4 bg-success text-white">
                    <h5>Total Users</h5>
                    <h2>@ViewBag.TotalUsers</h2>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card text-center p-4 bg-warning text-dark">
                    <h5>Total Rooms</h5>
                    <h2>@ViewBag.TotalRooms</h2>
                </div>
            </div>
        </div>

    </div>
</body>
</html>