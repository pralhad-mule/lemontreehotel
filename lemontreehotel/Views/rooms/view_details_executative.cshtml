@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Executive Room Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(to right, #f8f9fa, #eef2f7);
            font-family: 'Poppins', sans-serif;
        }

        .room-container {
            max-width: 1100px;
            margin: 40px auto;
        }

        .room-card {
            border: none;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
            background: #fff;
        }

        .room-header {
            background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
            color: white;
            padding: 30px;
            text-align: center;
            position: relative;
        }

            .room-header h1 {
                font-size: 38px;
                font-weight: 700;
            }

        .badge-room {
            background: #198754;
            padding: 10px 18px;
            font-size: 15px;
            border-radius: 30px;
        }

        .room-img {
            width: 100%;
            height: 500px;
            object-fit: cover;
        }

        .price {
            color: #2c5364;
            font-size: 40px;
            font-weight: 700;
        }

        .capacity {
            color: #555;
            font-weight: 600;
        }

        .section-title {
            color: #2c5364;
            font-size: 26px;
            font-weight: 700;
            margin-top: 30px;
        }

        .description {
            color: #666;
            font-size: 17px;
            line-height: 1.9;
            text-align: justify;
        }

        .facility-list {
            list-style: none;
            padding: 0;
        }

            .facility-list li {
                background: #eef3f7;
                border-left: 5px solid #2c5364;
                padding: 15px 20px;
                margin-bottom: 12px;
                border-radius: 12px;
                font-size: 18px;
            }

        .btn-book {
            background: linear-gradient(135deg, #0f2027, #2c5364);
            color: white;
            border: none;
            padding: 14px 45px;
            font-size: 18px;
            font-weight: 600;
            border-radius: 50px;
            text-decoration: none;
        }

            .btn-book:hover {
                background: #1c2f3a;
                color: white;
            }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: white;
            color: #2c5364;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
        }

            .back-btn:hover {
                background: #e6eef5;
            }
    </style>
</head>

<body>

    <div class="container room-container">

        <div class="card room-card">

            <div class="room-header">

                <a href="@Url.Action("Room","rooms")" class="back-btn">
                    ← Back
                </a>

                <h1>💼 Executive Room</h1>
                <span class="badge badge-room">Available</span>

            </div>

            <img src="~/Imagess/rooms/Executativeroom.jpg" class="room-img" alt="Executive Room">

            <div class="card-body p-4">

                <div class="row">
                    <div class="col-md-6">
                        <h2 class="price">₹6,500 / Night</h2>
                    </div>

                    <div class="col-md-6 text-md-end">
                        <h4 class="capacity">👥 3–4 Guests</h4>
                    </div>
                </div>

                <h3 class="section-title">Room Description</h3>

                <p class="description">
                    The Executive Room is designed for business travelers who require
                    comfort, elegance, and productivity. It provides a peaceful environment
                    with modern amenities, making it ideal for corporate stays and work trips.
                </p>

                <h3 class="section-title">Facilities & Amenities</h3>

                <ul class="facility-list">
                    <li>📶 High-Speed Wi-Fi</li>
                    <li>🖥️ Work Desk with Comfortable Chair</li>
                    <li>📺 Smart TV with Streaming Support</li>
                    <li>❄️ Air Conditioning</li>
                    <li>☕ Tea / Coffee Maker</li>
                    <li>🛏️ King Size Premium Bed</li>
                    <li>🧊 Mini Bar</li>
                    <li>🚿 Luxury Bathroom Amenities</li>
                    <li>🔌 Charging Ports & Work Station</li>
                    <li>🧹 Daily Housekeeping</li>
                    <li>🅿️ Parking Facility</li>
                </ul>

                <div class="text-center mt-4">
                    <a href="book_room" class="btn-book">Book Now</a>
                </div>

            </div>

        </div>

    </div>

</body>
</html>