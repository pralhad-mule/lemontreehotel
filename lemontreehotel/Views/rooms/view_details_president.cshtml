@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Presidential Suite Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(to right, #f8f9fa, #eef2f7);
            font-family: 'Poppins', sans-serif;
        }

        .room-container {
            max-width: 1100px;
            margin: 40px auto;
        }

        .room-card {
            border: none;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
            background: #fff;
        }

        .room-header {
            background: linear-gradient(135deg, #1f2937, #f59e0b);
            color: white;
            padding: 30px;
            text-align: center;
            position: relative;
        }

            .room-header h1 {
                font-size: 38px;
                font-weight: 700;
            }

        .badge-room {
            background: #198754;
            padding: 10px 18px;
            font-size: 15px;
            border-radius: 30px;
        }

        .room-img {
            width: 100%;
            height: 500px;
            object-fit: cover;
        }

        .price {
            color: #f59e0b;
            font-size: 42px;
            font-weight: 700;
        }

        .capacity {
            color: #555;
            font-weight: 600;
        }

        .section-title {
            color: #f59e0b;
            font-size: 26px;
            font-weight: 700;
            margin-top: 30px;
        }

        .description {
            color: #666;
            font-size: 17px;
            line-height: 1.9;
            text-align: justify;
        }

        .facility-list {
            list-style: none;
            padding: 0;
        }

            .facility-list li {
                background: #fffaf2;
                border-left: 5px solid #f59e0b;
                padding: 15px 20px;
                margin-bottom: 12px;
                border-radius: 12px;
                font-size: 18px;
            }

        .btn-book {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: white;
            border: none;
            padding: 14px 45px;
            font-size: 18px;
            font-weight: 600;
            border-radius: 50px;
            text-decoration: none;
        }

            .btn-book:hover {
                background: #b45309;
                color: white;
            }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: white;
            color: #f59e0b;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
        }

            .back-btn:hover {
                background: #fff3dd;
            }
    </style>
</head>

<body>

    <div class="container room-container">

        <div class="card room-card">

            <!-- Header -->
            <div class="room-header">
                <a href="@Url.Action("Room","rooms")" class="back-btn">← Back</a>

                <h1>👑 Presidential Suite</h1>
                <span class="badge badge-room">Luxury Stay</span>
            </div>

            <!-- Image -->
            <img src="~/Imagess/rooms/presendiital.jpg" class="room-img" alt="Presidential Suite">

            <div class="card-body p-4">

                <!-- Price & Capacity -->
                <div class="row">
                    <div class="col-md-6">
                        <h2 class="price">₹18,000 / Night</h2>
                    </div>

                    <div class="col-md-6 text-md-end">
                        <h4 class="capacity">👥 8 Guests</h4>
                    </div>
                </div>

                <!-- Description -->
                <h3 class="section-title">Room Description</h3>

                <p class="description">
                    Experience unmatched luxury in our Presidential Suite.
                    Designed for VIP guests, this suite offers world-class comfort,
                    premium interiors, spacious living area, and exclusive services.
                    Perfect for business leaders, celebrities, and high-profile guests
                    seeking ultimate luxury and privacy.
                </p>

                <!-- Facilities -->
                <h3 class="section-title">Facilities & Amenities</h3>

                <ul class="facility-list">
                    <li>🛏️ King Size Luxury Beds</li>
                    <li>📶 High-Speed Wi-Fi</li>
                    <li>📺 55” Smart TV</li>
                    <li>🍷 Private Mini Bar</li>
                    <li>🛋️ Luxury Living Area</li>
                    <li>🌅 City View Balcony</li>
                    <li>🍽️ Complimentary Breakfast & Dinner</li>
                    <li>🧴 Premium Toiletries</li>
                    <li>❄️ Air Conditioner</li>
                    <li>☕ Coffee Machine</li>
                    <li>🛎️ 24/7 Room Service</li>
                    <li>🚿 Luxury Bathroom with Bathtub</li>
                </ul>

                <!-- Book Button -->
                <div class="text-center mt-4">
                    <a href="book_room" class="btn-book">Book Now</a>
                </div>

            </div>
        </div>

    </div>

</body>
</html>